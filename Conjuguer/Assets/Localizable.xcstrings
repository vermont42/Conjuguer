    "Onboarding.learnBody" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Read in-depth treatises on every French tense, illustrated with examples from French literature—from the Chanson de Roland to Proust—alongside a history of the French verb."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lisez des traités approfondis sur chaque temps français, illustrés d’exemples tirés de la littérature française — de la Chanson de Roland à Proust — ainsi qu’une histoire du verbe français."
          }
        }
      }
    },
    "Onboarding.learnTitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deep-Dive Articles"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Articles approfondis"
          }
        }
      }
    },
    "Onboarding.modelsBody" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Discover the conjugation models that French verbs follow. Each model captures a distinct pattern of stem changes and endings. Understanding models helps you predict how unfamiliar verbs behave and recognize the irregularities that set them apart."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Découvrez les modèles de conjugaison que suivent les verbes français. Chaque modèle illustre un schéma distinct d’altérations du radical et de terminaisons. Comprendre les modèles vous aide à prévoir le comportement des verbes inconnus et à reconnaître les irrégularités qui les distinguent."
          }
        }
      }
    },
    "Onboarding.modelsTitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Explore Verb Models"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Explorez les modèles de verbes"
          }
        }
      }
    },
    "Onboarding.onboarding" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Onboarding"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Présentation"
          }
        }
      }
    },
    "Onboarding.quizBody" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Take timed quizzes, earn points, and compete on the Game Center leaderboard. Choose regular or ridiculous difficulty. The latter includes tenses rarely seen outside formal or literary writing. The reward for ridiculous difficulty is great: double the score."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites des quiz chronométrés, gagnez des points et affrontez les autres sur le classement Game Center. Choisissez la difficulté ordinaire ou ridicule. Cette dernière inclut des temps que l’on rencontre rarement en dehors de l’écrit formel ou littéraire. La récompense de la difficulté ridicule est grande : le score est doublé."
          }
        }
      }
    },
