    "Onboarding.browseBody" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Explore 6,320 verbs across every conjugation pattern. Tap any verb to see its full conjugation table with irregularities highlighted. Sort verbs by frequency of use for study purposes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Explorez 6 320 verbes répartis sur tous les modèles de conjugaison. Touchez un verbe pour afficher son tableau de conjugaison complet, avec les irrégularités mises en évidence. Triez les verbes par fréquence d’usage pour faciliter l’étude."
          }
        }
      }
    },
