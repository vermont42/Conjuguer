    "Settings.quizDifficultyDescription": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This setting determines the difficulty of quizzes. You probably want Regular because Ridiculous includes tenses and verbs that are not in widespread use."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce paramètre détermine la difficulté des quiz. Vous voulez probablement Ordinaire parce que Ridicule comprend des temps et des verbes qui ne sont pas d’usage très répandu."
          }
        }
      }
    },
