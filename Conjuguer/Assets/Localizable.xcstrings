    "Settings.pronounGenderDescription": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This setting determines pronoun genders, which matters for certain compound-tense conjugations. “Both” means that singular pronouns are feminine and that plural pronouns are masculine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce paramètre détermine le genre du pronom, ce qui est important pour certaines conjugaisons aux temps composés. « Les deux » signifie que les pronoms singuliers sont féminins et que les pronoms pluriels sont masculins."
          }
        }
      }
    },
    "Settings.quizDifficulty": {
